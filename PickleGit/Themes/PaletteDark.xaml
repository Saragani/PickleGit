<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ─────────────────────────────────────────────────────────── -->
    <Color x:Key="BackgroundColor">#FF171B21</Color>
    <Color x:Key="SurfaceColor">#FF1F2429</Color>
    <Color x:Key="SurfaceAltColor">#FF2A3040</Color>
    <Color x:Key="BorderColor">#FF2E3540</Color>
    <Color x:Key="TextPrimaryColor">#FFE0E4EC</Color>
    <Color x:Key="TextSecondaryColor">#FF8A95A3</Color>
    <Color x:Key="AccentColor">#FF7B5EA7</Color>
    <Color x:Key="AccentHoverColor">#FF9174BE</Color>
    <Color x:Key="SelectionColor">#FF253655</Color>
    <Color x:Key="SelectionBorderColor">#FF7B5EA7</Color>
    <Color x:Key="SuccessColor">#FF6FBE72</Color>
    <!-- Separate from SuccessColor (used for small badges/text, deliberately light/legible on a
         dark row background): SuccessColor is too light for white text on a solid button fill
         (WCAG contrast ~2.2:1). This is a dedicated dark green tuned for that use — same value in
         both palettes since a solid accent-style button doesn't need per-theme differentiation
         the way surfaces/text do, and re-tuning per theme risks reintroducing the same problem. -->
    <Color x:Key="SuccessButtonColor">#FF2E7D32</Color>
    <!-- Hover backgrounds for the solid Accent/Danger/Success-style buttons — a lighter tint of
         the same hue (matching AccentHoverColor's existing relationship to AccentColor), NOT the
         generic SurfaceAltBrush every plain ToolbarButton hovers to: that's pale in Light theme,
         which against white Foreground text reads as white-on-near-white while hovering. -->
    <Color x:Key="SuccessButtonHoverColor">#FF429146</Color>
    <Color x:Key="DangerColor">#FFBE4B48</Color>
    <Color x:Key="DangerHoverColor">#FFD25F5C</Color>
    <Color x:Key="WarningColor">#FFD19A66</Color>
    <Color x:Key="AddedColor">#FF1E3D1E</Color>
    <Color x:Key="DeletedColor">#FF3D1E1E</Color>
    <Color x:Key="TagColor">#FF5A4010</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessButtonBrush" Color="{StaticResource SuccessButtonColor}"/>
    <SolidColorBrush x:Key="SuccessButtonHoverBrush" Color="{StaticResource SuccessButtonHoverColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="AddedBrush" Color="{StaticResource AddedColor}"/>
    <SolidColorBrush x:Key="DeletedBrush" Color="{StaticResource DeletedColor}"/>
    <SolidColorBrush x:Key="TagBrush" Color="{StaticResource TagColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- ── Extended palette (views + templates that used to hardcode these) ── -->
    <SolidColorBrush x:Key="HunkHeaderBrush" Color="#FF1B2A3A"/>
    <SolidColorBrush x:Key="BannerWarningBrush" Color="#FF3A2F1B"/>
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FF23282E"/>
    <SolidColorBrush x:Key="DetachedBadgeBrush" Color="#FFB35C00"/>
    <SolidColorBrush x:Key="OverlayScrimBrush" Color="#BB171B21"/>
    <SolidColorBrush x:Key="GhostBackgroundBrush" Color="#EE2D333B"/>
    <SolidColorBrush x:Key="StagedTintBrush" Color="#1A4CAF50"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF4A515C"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF6A7180"/>
    <SolidColorBrush x:Key="BandAltBrush" Color="#14FFFFFF"/>

    <!-- Diff line colors (consumed by DiffLineBackground/ForegroundConverter). Added/Deleted row
         tints are deliberately translucent (alpha ~46/255) and lower-alpha than the word-diff
         highlight brushes (WordDiffHighlighter, alpha 110) so the row background stays subordinate
         and doesn't fight with the (now syntax-colored, not diff-colored) text on top of it. -->
    <SolidColorBrush x:Key="DiffAddedBgBrush" Color="#462EA043"/>
    <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="#46DC3C3C"/>
    <SolidColorBrush x:Key="DiffHeaderBgBrush" Color="#FF1B2A3A"/>
    <SolidColorBrush x:Key="DiffAddedFgBrush" Color="#FF67AD50"/>
    <SolidColorBrush x:Key="DiffDeletedFgBrush" Color="#FFBE4B48"/>
    <SolidColorBrush x:Key="DiffHeaderFgBrush" Color="#FF5C9BD6"/>
    <SolidColorBrush x:Key="DiffDefaultFgBrush" Color="#FFD5D8DE"/>

    <!-- Line-selection overlay (click/shift/drag in the diff view) — deliberately a blue distinct
         from both the green/red add/delete row backgrounds and the amber word-diff/search highlights. -->
    <SolidColorBrush x:Key="LineSelectionBrush" Color="#555C9BD6"/>

    <!-- Find-in-diff match highlight — amber, distinct from the green/red word-diff highlight hue. -->
    <SolidColorBrush x:Key="DiffSearchMatchBrush" Color="#66E0B000"/>
    <SolidColorBrush x:Key="DiffSearchCurrentMatchBrush" Color="#AAFFC400"/>
</ResourceDictionary>
