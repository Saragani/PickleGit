<Window x:Class="PickleGit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:PickleGit.ViewModels"
        xmlns:ctrl="clr-namespace:PickleGit.Controls"
        xmlns:conv="clr-namespace:PickleGit.Converters"
        xmlns:behaviors="clr-namespace:PickleGit.Behaviors"
        xmlns:models="clr-namespace:PickleGit.Models"
        xmlns:views="clr-namespace:PickleGit.Views"
        Title="PickleGit" Height="800" Width="1280" MinWidth="900" MinHeight="600"
        Icon="Resources/pickle.ico"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource DarkWindow}"
        WindowStartupLocation="CenterScreen">

    <!-- InputBindings are built dynamically in code-behind (MainWindow.xaml.cs, RebuildInputBindings)
         from Services/ShortcutManager.cs, so Settings → Shortcuts overrides take effect without
         restarting. See CLAUDE.md "Keyboard shortcuts" for why. -->

    <Window.Resources>
        <!-- ── Dark TabItem style ──────────────────────────────────────────── -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TabItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="PreviewMouseMove"           Handler="TabItem_PreviewMouseMove"/>
            <EventSetter Event="PreviewMouseLeftButtonUp"   Handler="TabItem_PreviewMouseLeftButtonUp"/>
            <!-- Tag carries the AppViewModel for ContextMenu bindings (PlacementTarget.Tag trick) -->
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Close"
                                  Command="{Binding PlacementTarget.Tag.CloseTabCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  InputGestureText="Ctrl+W"/>
                        <MenuItem Header="Close others"
                                  Command="{Binding PlacementTarget.Tag.CloseOtherTabsCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Close tabs to the right"
                                  Command="{Binding PlacementTarget.Tag.CloseTabsToRightCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Close all"
                                  Command="{Binding PlacementTarget.Tag.CloseAllTabsCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="Copy repository path"
                                  Command="{Binding PlacementTarget.Tag.CopyRepoPathCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Open in Explorer"
                                  Command="{Binding PlacementTarget.Tag.OpenRepoInExplorerCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Open terminal here"
                                  Command="{Binding PlacementTarget.Tag.OpenTerminalCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="14,8">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark TabControl style ──────────────────────────────────────── -->
        <Style x:Key="DarkTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          Background="Transparent"/>
                            </Border>
                            <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab close button style ─────────────────────────────────────── -->
        <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBusyIndicator" TargetType="Path">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Data" Value="M 7,1 A 6,6 0 1 1 2.75,2.75"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="TabBusyStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                 From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="TabBusyStoryboard"/>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Tabs -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,6">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: repo name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActiveTab.RepoName, FallbackValue='(no repository)'}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                </StackPanel>

                <!-- Center: Open / Clone / Init — centered within the space left by the side columns,
                     so it can never overlap them (each side column reserves its own Auto width). -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="📂  Open" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenRepoCommand}" Margin="2,0" ToolTip="Open repository in new tab"/>
                    <Button Content="⬇  Clone" Style="{StaticResource ToolbarButton}"
                            Command="{Binding CloneRepoCommand}" Margin="2,0" ToolTip="Clone repository"/>
                    <Button Content="＋  Init" Style="{StaticResource ToolbarButton}"
                            Command="{Binding InitRepoCommand}" Margin="2,0" ToolTip="Initialize new repository"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <!-- Slim dropdown-arrow companion button -->
                        <Style x:Key="DropdownArrow" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Setter Property="Padding" Value="2,4"/>
                            <Setter Property="Margin" Value="0,0,2,0"/>
                            <Setter Property="FontSize" Value="8"/>
                            <Setter Property="Content" Value="▼"/>
                        </Style>
                    </StackPanel.Resources>
                    <Separator Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
                    <Button Content="↻  Fetch" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.FetchCommand}" Margin="2,0,0,0" ToolTip="Fetch from remote"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource DropdownArrow}" Click="DropdownButton_Click"
                            ToolTip="Fetch options"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Fetch"
                                          Command="{Binding ActiveTab.FetchCommand}"/>
                                <MenuItem Header="Fetch and prune deleted branches"
                                          Command="{Binding ActiveTab.FetchPruneCommand}"/>
                                <MenuItem Header="Fetch all remotes"
                                          Command="{Binding ActiveTab.FetchAllCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="⬇  Pull" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.PullCommand}" Margin="2,0,0,0" ToolTip="Pull (merge)"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource DropdownArrow}" Click="DropdownButton_Click"
                            ToolTip="Pull options"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Pull (merge)"
                                          Command="{Binding ActiveTab.PullCommand}"/>
                                <MenuItem Header="Pull (rebase)"
                                          Command="{Binding ActiveTab.PullRebaseCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="⬆  Push" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.PushCommand}" Margin="2,0,0,0" ToolTip="Push"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource DropdownArrow}" Click="DropdownButton_Click"
                            ToolTip="Push options"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Push"
                                          Command="{Binding ActiveTab.PushCommand}"/>
                                <MenuItem Header="Force push (with lease)…"
                                          Command="{Binding ActiveTab.ForcePushCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Separator Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                    <Button Content="⎇  Branch" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.CreateBranchCommand}" Margin="2,0" ToolTip="Create branch"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Content="📦  Stash" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.StashCommand}" Margin="2,0" ToolTip="Stash changes"
                            IsEnabled="{Binding ActiveTab.IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Separator Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                    <Button Content="±  Commit" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.ShowWorkingDirCommand}" Margin="2,0" ToolTip="Show staging area"/>
                    <Separator Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                    <Button Content="?" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenHelpCommand}" Margin="2,0" ToolTip="Help"/>
                    <Button Content="&#x2699;" Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenSettingsCommand}" Margin="2,0" ToolTip="Settings"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══ PROGRESS BAR ══════════════════════════════════════════════════ -->
        <!-- ═══ TABS ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <TabControl x:Name="MainTabControl"
                        ItemsSource="{Binding Tabs}"
                        SelectedItem="{Binding ActiveTab}"
                        Style="{StaticResource DarkTabControl}"
                        ItemContainerStyle="{StaticResource DarkTabItem}">

                <!-- ── Tab header: repo name + close button ────────────────── -->
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RepoName}" VerticalAlignment="Center" FontSize="15"/>
                            <Path Style="{StaticResource TabBusyIndicator}"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="✕"
                                AutomationProperties.Name="Close tab"
                                    Style="{StaticResource TabCloseButton}"
                                    Command="{Binding DataContext.CloseTabCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Close tab"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <!-- ── Tab content: full 3-panel layout ───────────────────── -->
                <TabControl.ContentTemplate>
                    <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230" MinWidth="210" MaxWidth="400"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*" MinWidth="300"/>
                                <ColumnDefinition Width="{Binding DetailSplitterWidth}"/>
                                <ColumnDefinition Width="{Binding DetailPanelWidth}" MinWidth="{Binding DetailPanelMinWidth}" MaxWidth="600"/>
                            </Grid.ColumnDefinitions>

                            <views:SidebarView Grid.Column="0"/>
                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                            <Grid Grid.Column="2">
                                <!-- S single selected file takes over this whole
                                     pane with its diff instead of sitting in a fixed-height strip that's
                                     dead space whenever nothing's selected; 0 or 2+ selected files show
                                     the commit graph instead (see ShowDiffInsteadOfCommits). -->
                                <views:CommitListView Visibility="{Binding ShowDiffInsteadOfCommits, Converter={StaticResource InvertBoolToVis}}"/>
                                <views:DiffView Visibility="{Binding ShowDiffInsteadOfCommits, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                                          Visibility="{Binding HasDetailPanel, Converter={StaticResource BoolToVis}}"/>
                            <views:CommitDetailView Grid.Column="4"
                                                    Visibility="{Binding HasDetailPanel, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>

            </TabControl>

            <!-- Empty state when no tabs are open -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False"
                        Visibility="{Binding Tabs.Count, Converter={StaticResource IntAboveZero},
                                     ConverterParameter=Invert}">
                <TextBlock Text="No repository open"
                           FontSize="20" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Click  📂 Open  or  ⬇ Clone  to get started"
                           FontSize="13" Margin="0,8,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════════ -->
        <!-- MinHeight reserves space for the tallest possible content (Cancel/Undo buttons) so their
             Visibility flipping to Visible doesn't grow this Auto row and shift the Tabs row above it. -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,4" MinHeight="28">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⎇ " Foreground="{DynamicResource AccentBrush}" FontSize="12"
                               Visibility="{Binding ActiveTab.CurrentBranch, Converter={StaticResource InvertDetachedVis}}"/>
                    <TextBlock Text="{Binding ActiveTab.CurrentBranch, FallbackValue=''}"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                               Visibility="{Binding ActiveTab.CurrentBranch, Converter={StaticResource InvertDetachedVis}}"/>
                    <Border Background="{DynamicResource DetachedBadgeBrush}" CornerRadius="3" Padding="6,1"
                            Visibility="{Binding ActiveTab.CurrentBranch, Converter={StaticResource DetachedVis}}"
                            ToolTip="HEAD is not on a branch — commits here can be lost unless you create a branch or tag.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A0; " FontSize="11" Foreground="White"/>
                            <TextBlock Text="{Binding ActiveTab.CurrentBranch, FallbackValue=''}"
                                       FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="&#x2715; Cancel" FontSize="11" Padding="6,1" Margin="0,0,10,0"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ActiveTab.CancelOperationCommand}"
                            Visibility="{Binding ActiveTab.CanCancel, Converter={StaticResource BoolToVis}}"
                            ToolTip="Cancel the running operation"/>
                    <Button Content="&#x21A9; Undo" FontSize="11" Padding="6,1" Margin="0,0,10,0"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding ActiveTab.UndoCommand}"
                            Visibility="{Binding ActiveTab.CanUndo, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding ActiveTab.LastUndo.Description, StringFormat='Undo: {0}'}"/>
                    <ProgressBar Width="120" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding ActiveTab.ProgressPercent, Mode=OneWay, FallbackValue=0}"
                                 Visibility="{Binding ActiveTab.HasProgress, Converter={StaticResource BoolToVis},
                                              FallbackValue=Collapsed}"/>
                    <TextBlock Text="{Binding ActiveTab.StatusMessage, FallbackValue='Ready'}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab drag ghost overlay — floats above everything during drag -->
        <Canvas x:Name="TabDragCanvas" Panel.ZIndex="100" IsHitTestVisible="False"
                Grid.RowSpan="3">
            <Border x:Name="TabDragGhost" Visibility="Collapsed" IsHitTestVisible="False"
                    Background="{DynamicResource GhostBackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,0,0,2"
                    Padding="14,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="4" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TabDragGhostLabel" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" FontSize="15"/>
                    <TextBlock Text="✕" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
