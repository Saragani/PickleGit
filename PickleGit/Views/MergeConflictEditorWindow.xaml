<Window x:Class="PickleGit.Views.MergeConflictEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding FilePath, StringFormat='Resolve Conflict — {0}'}"
        Width="1040" Height="720" MinWidth="760" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/pickle.ico"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding FilePath}" FontWeight="SemiBold" FontSize="14"
                   Margin="0,0,0,10" TextTrimming="CharacterEllipsis"/>

        <!-- Block navigator -->
        <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" CornerRadius="4"
                Padding="10,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#x25C0;" Width="26" Style="{StaticResource ToolbarButton}"
                            Command="{Binding PrevBlockCommand}" ToolTip="Previous conflict block"/>
                    <TextBlock Text="{Binding BlockPositionLabel}" VerticalAlignment="Center"
                               Margin="10,0" FontSize="12"/>
                    <Button Content="&#x25B6;" Width="26" Style="{StaticResource ToolbarButton}"
                            Command="{Binding NextBlockCommand}" ToolTip="Next conflict block"/>
                    <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="Status: "/>
                        <Run Text="{Binding CurrentBlock.Resolution, Mode=OneWay, FallbackValue=Unresolved}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Take Ours" Style="{StaticResource ToolbarButton}" Padding="10,4"
                            Command="{Binding TakeOursCommand}" Margin="0,0,6,0"/>
                    <Button Content="Take Theirs" Style="{StaticResource ToolbarButton}" Padding="10,4"
                            Command="{Binding TakeTheirsCommand}" Margin="0,0,6,0"/>
                    <Button Content="Take Base" Style="{StaticResource ToolbarButton}" Padding="10,4"
                            Command="{Binding TakeBaseCommand}" Margin="0,0,6,0"
                            ToolTip="Use the common-ancestor version (diff3 conflict style)"
                            Visibility="{Binding CurrentBlock.BaseText, Converter={StaticResource NullToVis}}"/>
                    <Button Content="Keep Both" Style="{StaticResource ToolbarButton}" Padding="10,4"
                            Command="{Binding TakeBothCommand}" Margin="0,0,6,0"
                            ToolTip="Ours first, then theirs"/>
                    <Button Content="Keep Both ⇅" Style="{StaticResource ToolbarButton}" Padding="10,4"
                            Command="{Binding TakeBothReverseCommand}"
                            ToolTip="Theirs first, then ours"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- OURS | BASE (diff3 only) | THEIRS reference panes -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <!-- BASE column collapses to zero when the conflict has no diff3 base section -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentBlock.BaseText}" Value="{x:Null}">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentBlock.BaseText}" Value="{x:Null}">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"
                           Foreground="{DynamicResource AccentBrush}"
                           Text="{Binding CurrentBlock.OursLabel, FallbackValue=Ours}"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBox Text="{Binding OursText, Mode=OneWay}" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </DockPanel>

            <DockPanel Grid.Column="2"
                       Visibility="{Binding CurrentBlock.BaseText, Converter={StaticResource NullToVis}}">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="BASE (common ancestor)"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBox Text="{Binding CurrentBlock.BaseText, Mode=OneWay}" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </DockPanel>

            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"
                           Foreground="{DynamicResource WarningBrush}"
                           Text="{Binding CurrentBlock.TheirsLabel, FallbackValue=Theirs}"/>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <TextBox Text="{Binding TheirsText, Mode=OneWay}" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             FontFamily="Consolas" FontSize="11"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </DockPanel>
        </Grid>

        <!-- RESULT (editable) -->
        <DockPanel Grid.Row="4">
            <TextBlock DockPanel.Dock="Top" FontSize="11" Margin="0,0,0,4">
                <Run Text="RESULT (editable)" FontWeight="SemiBold"/>
                <Run Text="  —  "/>
                <Run Foreground="{DynamicResource TextSecondaryBrush}"
                     Text="{Binding UnresolvedCount, Mode=OneWay, StringFormat='{}{0} unresolved marker block(s)'}"/>
            </TextBlock>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <TextBox Text="{Binding ResultText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         FontFamily="Consolas" FontSize="11"
                         Background="{DynamicResource BackgroundBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </Border>
        </DockPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}" MinWidth="90" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Save &amp; Resolve" Style="{StaticResource AccentButton}" MinWidth="140"
                    Command="{Binding SaveCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
