<Window x:Class="PickleGit.Views.MergeConflictEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PickleGit.ViewModels"
        xmlns:conv="clr-namespace:PickleGit.Converters"
        Title="Resolve Conflicts"
        Width="1240" Height="780" MinWidth="900" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/pickle.ico"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:ConflictViewItemTemplateSelector x:Key="ConflictItemSelector">
                <conv:ConflictViewItemTemplateSelector.ContextTemplate>
                    <DataTemplate DataType="{x:Type vm:ConflictViewItem}">
                        <TextBlock Text="{Binding ContextText}" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Margin="4,2"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DataTemplate>
                </conv:ConflictViewItemTemplateSelector.ContextTemplate>
                <conv:ConflictViewItemTemplateSelector.BlockTemplate>
                    <DataTemplate DataType="{x:Type vm:ConflictViewItem}">
                        <Border Margin="0,4" Padding="10" CornerRadius="4" BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource BackgroundBrush}">
                            <Grid>
                                <!-- Unresolved: Ours / (Base) / Theirs stacked, each with its own accept
                                     button — no "current block" navigation needed, any block can be
                                     resolved directly from its own card. -->
                                <StackPanel Visibility="{Binding Block.Resolution, Converter={StaticResource UnresolvedVis}}">
                                    <DockPanel Margin="0,0,0,6" LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Text="{Binding Block.OursLabel}"/>
                                        <Border DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Accept Mine" Style="{StaticResource ToolbarButton}"
                                                        Padding="8,3" Margin="0,0,4,0"
                                                        Command="{Binding AcceptMineCommand}"/>
                                                <Button Content="Accept Theirs" Style="{StaticResource ToolbarButton}"
                                                        Padding="8,3" Margin="0,0,4,0"
                                                        Command="{Binding AcceptTheirsCommand}"/>
                                                <Button Content="Accept Base" Style="{StaticResource ToolbarButton}"
                                                        Padding="8,3" Margin="0,0,4,0"
                                                        Command="{Binding AcceptBaseCommand}"
                                                        Visibility="{Binding Block.BaseText, Converter={StaticResource NullToVis}}"/>
                                                <Button Content="Both" Style="{StaticResource ToolbarButton}"
                                                        Padding="8,3" Margin="0,0,4,0"
                                                        ToolTip="Keep both — mine, then theirs"
                                                        Command="{Binding AcceptBothCommand}"/>
                                                <Button Content="Both ⇅" Style="{StaticResource ToolbarButton}"
                                                        Padding="8,3" ToolTip="Keep both — theirs, then mine"
                                                        Command="{Binding AcceptBothReverseCommand}"/>
                                            </StackPanel>
                                        </Border>
                                    </DockPanel>
                                    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Margin="0,0,0,4">
                                        <TextBox Text="{Binding Block.OursText, Mode=OneWay}" IsReadOnly="True"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Background="{DynamicResource BackgroundBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0" MaxHeight="160"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Border>
                                    <Border BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1" Margin="0,0,0,4"
                                            Visibility="{Binding Block.BaseText, Converter={StaticResource NullToVis}}">
                                        <TextBox Text="{Binding Block.BaseText, Mode=OneWay}" IsReadOnly="True"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Background="{DynamicResource BackgroundBrush}"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                 BorderThickness="0" MaxHeight="120"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Border>
                                    <TextBlock FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"
                                               Foreground="{DynamicResource WarningBrush}"
                                               Text="{Binding Block.TheirsLabel}"/>
                                    <Border BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
                                        <TextBox Text="{Binding Block.TheirsText, Mode=OneWay}" IsReadOnly="True"
                                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Background="{DynamicResource BackgroundBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0" MaxHeight="160"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Border>
                                </StackPanel>

                                <!-- Resolved: collapsed single strip showing what was kept -->
                                <Border Visibility="{Binding Block.Resolution, Converter={StaticResource ResolvedVis}}"
                                        BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="0,0,0,0"
                                        Padding="0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ResolvedLabel}" FontSize="10" FontStyle="Italic"
                                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,4"/>
                                        <Border BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
                                            <TextBox Text="{Binding ResolvedText, Mode=OneWay}" IsReadOnly="True"
                                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="{DynamicResource BackgroundBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderThickness="0" MaxHeight="160"
                                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </conv:ConflictViewItemTemplateSelector.BlockTemplate>
            </conv:ConflictViewItemTemplateSelector>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10">
            <Run Text="Resolve Conflicts"/>
            <Run Text="  —  "/>
            <Run Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Normal" FontSize="12"
                 Text="{Binding ResolvedCountLabel, Mode=OneWay}"/>
        </TextBlock>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File list -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ListView ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedEntry}"
                          Style="{StaticResource DarkListView}"
                          ItemContainerStyle="{StaticResource DarkListViewItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ConflictFileListEntry}">
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x2713;" FontWeight="Bold" VerticalAlignment="Top"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Visibility="{Binding IsResolved, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Column="0" Text="&#x26A0;" VerticalAlignment="Top"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Visibility="{Binding IsResolved, Converter={StaticResource InvertBoolToVis}}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Path}" FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                    <Border Background="{DynamicResource WarningBrush}" CornerRadius="3"
                                            Padding="4,1" Margin="0,2,0,0" HorizontalAlignment="Left"
                                            Visibility="{Binding ExistenceBadge, Converter={StaticResource NullToVis}}">
                                        <TextBlock Text="{Binding ExistenceBadge}" FontSize="9" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"/>

            <!-- Selected file detail -->
            <Grid Grid.Column="2" DataContext="{Binding CurrentFile}">
                <TextBlock Text="Select a file on the left to resolve it."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding ., Converter={StaticResource InvertNullToVis}}"/>

                <Grid Visibility="{Binding ., Converter={StaticResource NullToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="11">
                        <Run Text="{Binding RelativePath, Mode=OneWay}" FontWeight="SemiBold" FontFamily="Consolas"/>
                        <Run Text="  —  "/>
                        <Run Foreground="{DynamicResource TextSecondaryBrush}"
                             Text="{Binding BlockStatusLabel, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Existence (add/delete) conflict: no content to diff — keep or delete instead -->
                    <Border Grid.Row="1" Padding="16" VerticalAlignment="Top"
                            Visibility="{Binding IsExistenceConflict, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource BackgroundBrush}" BorderThickness="1"
                            BorderBrush="{DynamicResource WarningBrush}" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="{Binding ExistenceMessage}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Keep file" GroupName="ExistenceChoice" Margin="0,0,16,0"
                                             IsChecked="{Binding KeepFileChecked, Mode=OneWay}"
                                             Command="{Binding KeepFileCommand}"/>
                                <RadioButton Content="Delete file" GroupName="ExistenceChoice"
                                             IsChecked="{Binding DeleteFileChecked, Mode=OneWay}"
                                             Command="{Binding DeleteFileCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Content conflict: flattened, interleaved merged view — non-conflicting text
                         renders normally, each conflict block inline with its own accept buttons. -->
                    <ListView Grid.Row="1" ItemsSource="{Binding FlatItems}"
                              Style="{StaticResource DarkListView}"
                              ItemTemplateSelector="{StaticResource ConflictItemSelector}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsExistenceConflict, Converter={StaticResource InvertBoolToVis}}">
                        <!-- Rows vary hugely in height (a one-line context run vs a full Ours/Theirs
                             card) — plain StackPanel host, no virtualization; a single file's conflict
                             count is always small enough that this costs nothing (see CLAUDE.md's
                             VirtualizingStackPanel variable-height-row note for why this matters). -->
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DarkListViewItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Style="{StaticResource ToolbarButton}" MinWidth="90" Margin="0,0,8,0"
                    Command="{Binding CloseCommand}" IsCancel="True"/>
            <Button Content="Save &amp; Stage This File" Style="{StaticResource AccentButton}" MinWidth="170"
                    Command="{Binding SaveCurrentCommand}"/>
        </StackPanel>
    </Grid>
</Window>
