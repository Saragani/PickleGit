<Window x:Class="PickleGit.Views.Dialogs.CreatePullRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}" Height="460" Width="480"
        MinHeight="420" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/pickle.ico"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding HeaderText}" FontSize="15" FontWeight="SemiBold"/>

        <!-- From / To branches -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="From" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding SourceBranch}" FontSize="13" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Into" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox Name="TargetBox" Margin="0,4,0,0"
                          IsEditable="True" IsTextSearchEnabled="False"
                          Text="{Binding SelectedTargetBranch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          GotFocus="TargetBox_GotFocus"
                          TextBoxBase.TextChanged="TargetBox_TextChanged"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="4" Text="Title" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Grid.Row="6" Name="TitleBox" Style="{StaticResource DarkTextBox}"
                 Text="{Binding PrTitle, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="8" Text="Description (optional)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox Grid.Row="10" Name="DescriptionBox" Style="{StaticResource DarkTextBox}"
                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Height="90" VerticalContentAlignment="Top"/>

        <CheckBox Grid.Row="12" VerticalAlignment="Top" Content="Create as draft"
                  IsChecked="{Binding IsDraft}"
                  Visibility="{Binding SupportsDraft, Converter={StaticResource BoolToVis}}"/>

        <TextBlock Grid.Row="14" Text="{Binding StatusText}" Foreground="{DynamicResource DangerBrush}"
                   TextWrapping="Wrap"
                   Visibility="{Binding HasStatusText, Converter={StaticResource BoolToVis}}"/>

        <StackPanel Grid.Row="16" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0"
                    MinWidth="80" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="{Binding OkText}" Style="{StaticResource AccentButton}" MinWidth="80"
                    Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
