<UserControl x:Class="PickleGit.Views.CommitDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:PickleGit.ViewModels"
             xmlns:ctrl="clr-namespace:PickleGit.Controls"
             xmlns:conv="clr-namespace:PickleGit.Converters"
             xmlns:behaviors="clr-namespace:PickleGit.Behaviors"
             xmlns:models="clr-namespace:PickleGit.Models">

    <Grid Background="{DynamicResource SurfaceBrush}">

        <!-- COMMIT DETAIL VIEW -->
        <Grid Visibility="{Binding ShowWorkingDir, Converter={StaticResource InvertBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Bisect banner — shown regardless of whether a commit is selected or a comparison
                 is open, since bisecting is fundamentally about browsing/checking out commits. -->
            <Border Grid.Row="0" Background="{DynamicResource BannerWarningBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="0,0,0,1"
                    Padding="10,8" Visibility="{Binding HasBisect, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x1F50D;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Bisecting" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                       Visibility="{Binding BisectInfo.Found, Converter={StaticResource InvertBoolToVis}}"/>
                            <TextBlock Text="Bisect complete" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                       Visibility="{Binding BisectInfo.Found, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Visibility="{Binding BisectInfo.Found, Converter={StaticResource InvertBoolToVis}}">
                            <Button Content="Good" Style="{StaticResource SuccessButton}" Padding="10,3" Margin="0,0,6,0"
                                    Command="{Binding BisectGoodCommand}"/>
                            <Button Content="Bad" Style="{StaticResource DangerButton}" Padding="10,3" Margin="0,0,6,0"
                                    Command="{Binding BisectBadCommand}"/>
                            <Button Content="Skip" Style="{StaticResource ToolbarButton}" Padding="10,3" Margin="0,0,6,0"
                                    Command="{Binding BisectSkipCommand}"/>
                            <Button Content="Reset" Style="{StaticResource ToolbarButton}" Padding="10,3"
                                    Command="{Binding BisectResetCommand}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Reset" Style="{StaticResource AccentButton}" Padding="10,3"
                                Command="{Binding BisectResetCommand}"
                                Visibility="{Binding BisectInfo.Found, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding BisectInfo.Found, Converter={StaticResource InvertBoolToVis}}">
                        <Run Text="Testing "/>
                        <Run Text="{Binding BisectInfo.CurrentSha, Converter={StaticResource ShaShort}, Mode=OneWay}"
                             FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                        <Run Text="{Binding BisectInfo.RevisionsLeft, Converter={StaticResource BisectProgressText}, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding BisectInfo.Found, Converter={StaticResource BoolToVis}}">
                        <Run Text="First bad commit: "/>
                        <Run Text="{Binding BisectInfo.FirstBadSha, Converter={StaticResource ShaShort}, Mode=OneWay}"
                             FontFamily="Consolas" Foreground="{DynamicResource DangerBrush}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding BisectInfo.FirstBadSummary, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="12,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding DetailCommit, Converter={StaticResource NullToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding DetailCommit.MessageShort}"
                               FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Margin="0,6,0,0" FontSize="11">
                        <Run Foreground="{DynamicResource TextSecondaryBrush}" Text="Author: "/>
                        <Run Text="{Binding DetailCommit.AuthorName}"/>
                        <Run Foreground="{DynamicResource TextSecondaryBrush}" Text=" &lt;"/>
                        <Run Text="{Binding DetailCommit.AuthorEmail}"/>
                        <Run Foreground="{DynamicResource TextSecondaryBrush}" Text="&gt;"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0" FontSize="11">
                        <Run Foreground="{DynamicResource TextSecondaryBrush}" Text="Date: "/>
                        <Run Text="{Binding DetailCommit.AuthorDate, Converter={StaticResource DateFmt}, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0" FontSize="11">
                        <Run Foreground="{DynamicResource TextSecondaryBrush}" Text="SHA: "/>
                        <Run Text="{Binding DetailCommit.ShortSha, Mode=OneWay}"
                             FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0" FontSize="11"
                               Text="{Binding SignatureStatus}"
                               Foreground="{DynamicResource SuccessBrush}"
                               Visibility="{Binding SignatureStatus, Converter={StaticResource NullToVis}}"/>
                </StackPanel>
            </Border>

            <!-- Ad-hoc "Diff against current branch" comparison — a third state alongside the
                 DetailCommit metadata block above and the empty-state placeholder below, all
                 sharing this same Row 0 cell (mutually exclusive via IsComparisonMode/DetailCommit). -->
            <Border Grid.Row="1" Padding="12,10"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding IsComparisonMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="Comparing "/>
                        <Run Text="{Binding ComparisonTargetName, Mode=OneWay}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                        <Run Text=" → "/>
                        <Run Text="{Binding ComparisonBaseName, Mode=OneWay}" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                    </TextBlock>
                    <Button Content="✕ Exit comparison" FontSize="10" Padding="6,2" Margin="0,6,0,0"
                            HorizontalAlignment="Left" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ExitComparisonCommand}"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1" Text="Select a commit to view details."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,20"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                       Visibility="{Binding ShowCommitFilesPanel, Converter={StaticResource InvertBoolToVis}}"/>

            <Border Grid.Row="2" Padding="12,6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Background="{DynamicResource BackgroundBrush}"
                    Visibility="{Binding ShowCommitFilesPanel, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding CommitFiles.Count, StringFormat='Files changed ({0})'}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>

            <ListView Grid.Row="3"
                      Style="{StaticResource DarkListView}"
                      ItemContainerStyle="{StaticResource DarkListViewItem}"
                      ItemsSource="{Binding CommitFiles}"
                      SelectedItem="{Binding SelectedFile}"
                      Visibility="{Binding ShowCommitFilesPanel, Converter={StaticResource BoolToVis}}"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:FileChange}">
                        <Grid Margin="8,0" Height="26" Background="Transparent"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="14" Height="14"
                                    Background="{Binding Kind, Converter={StaticResource KindToColor}}"
                                    CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="9" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Path}"
                                       VerticalAlignment="Center" Margin="6,0"
                                       TextTrimming="CharacterEllipsis" FontSize="11"/>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open"
                                              Command="{Binding PlacementTarget.Tag.OpenFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Reveal in Explorer"
                                              Command="{Binding PlacementTarget.Tag.RevealFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Copy path"
                                              Command="{Binding PlacementTarget.Tag.CopyFilePathCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="View File History"
                                              Command="{Binding PlacementTarget.Tag.ShowHistoryModeCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Blame"
                                              Command="{Binding PlacementTarget.Tag.ShowBlameModeCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Row="4" Padding="12,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Visibility="{Binding DetailCommit, Converter={StaticResource NullToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding DetailCommit.Message}" TextWrapping="Wrap"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </ScrollViewer>
            </Border>

            <!-- MULTI-SELECTION AGGREGATED VIEW -->
            <Grid Grid.Row="0" Grid.RowSpan="4"
                  Background="{DynamicResource SurfaceBrush}"
                  Visibility="{Binding IsMultiSelection, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: N commits selected -->
                <Border Grid.Row="0" Padding="12,10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                        <Run Text=" commits selected"/>
                    </TextBlock>
                </Border>

                <!-- Files changed count -->
                <Border Grid.Row="1" Padding="12,6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Background="{DynamicResource BackgroundBrush}">
                    <TextBlock Text="{Binding AggregatedFiles.Count, StringFormat='Files changed ({0})'}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <!-- Aggregated file list -->
                <ListView Grid.Row="2"
                          Style="{StaticResource DarkListView}"
                          ItemContainerStyle="{StaticResource DarkListViewItem}"
                          ItemsSource="{Binding AggregatedFiles}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:AggregatedFileChange}">
                            <Grid Height="26" Margin="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="14" Height="14"
                                        Background="{Binding Kind, Converter={StaticResource KindToColor}}"
                                        CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Path}"
                                           VerticalAlignment="Center" Margin="6,0"
                                           TextTrimming="CharacterEllipsis" FontSize="11"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                           Margin="4,0,6,0" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="&#xD7;"/><Run Text="{Binding CommitCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- STAGING / WORKING DIRECTORY VIEW -->
        <Grid Visibility="{Binding ShowWorkingDir, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Conflict banner -->
            <Border Grid.Row="0" Background="{DynamicResource BannerWarningBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="0,0,0,1"
                    Padding="10,8" Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                                <Run Text="{Binding ConflictInfo.OperationLabel, Mode=OneWay}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding ConflictInfo.SourceDescription, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Abort" Style="{StaticResource DangerButton}" Padding="10,3" Margin="0,0,6,0"
                                    Command="{Binding AbortOperationCommand}"/>
                            <Button Content="Continue" Style="{StaticResource AccentButton}" Padding="10,3"
                                    Command="{Binding ContinueOperationCommand}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding ConflictInfo.RebaseStepTotal, Converter={StaticResource IntAboveZero}}">
                        <Run Text="Step "/>
                        <Run Text="{Binding ConflictInfo.RebaseStepCurrent, Mode=OneWay}"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding ConflictInfo.RebaseStepTotal, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding ConflictInfo.ConflictedFiles.Count, StringFormat='{}{0} conflicted file(s)'}"/>
                    <ItemsControl ItemsSource="{Binding ConflictedFileChanges}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FileChange}">
                                <Grid Margin="0,3" Height="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Path}" VerticalAlignment="Center"
                                               FontSize="11" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Take Ours" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                                Style="{StaticResource ToolbarButton}"
                                                Command="{Binding DataContext.TakeOursCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Take Theirs" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                                Style="{StaticResource ToolbarButton}"
                                                Command="{Binding DataContext.TakeTheirsCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Open Editor" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                                Style="{StaticResource ToolbarButton}"
                                                Command="{Binding DataContext.OpenMergeEditorCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Mark Resolved" FontSize="10" Padding="6,2"
                                                Style="{StaticResource ToolbarButton}"
                                                Command="{Binding DataContext.MarkResolvedCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="12,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Staged Files" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource DangerButton}" Padding="8,3"
                                Content="{Binding SelectedStagedFiles.Count, Converter={StaticResource BulkActionLabel}, ConverterParameter=Unstage}"
                                Command="{Binding UnstageAllCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ListView x:Name="StagedListView" Grid.Row="2"
                      Style="{StaticResource DarkListView}"
                      ItemContainerStyle="{StaticResource DarkListViewItem}"
                      ItemsSource="{Binding StagedFiles}"
                      SelectedItem="{Binding SelectedFile}"
                      SelectionMode="Extended">
                <i:Interaction.Behaviors>
                    <behaviors:ListViewMultiSelectBehavior SelectedItems="{Binding SelectedStagedFiles}"/>
                </i:Interaction.Behaviors>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:FileChange}">
                        <Grid Height="26" Margin="4,0" Background="Transparent"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="14" Height="14"
                                    Background="{Binding Kind, Converter={StaticResource KindToColor}}"
                                    CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Path}" VerticalAlignment="Center"
                                       Margin="6,0" TextTrimming="CharacterEllipsis" FontSize="11"/>
                            <Button Grid.Column="2" Content="&#x2212;" Width="20" Height="20"
                                    Style="{StaticResource ToolbarButton}" Padding="0"
                                    Command="{Binding DataContext.UnstageFileCommand,
                                              RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Unstage"/>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Unstage"
                                              Command="{Binding PlacementTarget.Tag.UnstageFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Discard changes"
                                              Command="{Binding PlacementTarget.Tag.DiscardStagedFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Open"
                                              Command="{Binding PlacementTarget.Tag.OpenFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Reveal in Explorer"
                                              Command="{Binding PlacementTarget.Tag.RevealFileCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Copy path"
                                              Command="{Binding PlacementTarget.Tag.CopyFilePathCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="View File History"
                                              Command="{Binding PlacementTarget.Tag.ShowHistoryModeCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Blame"
                                              Command="{Binding PlacementTarget.Tag.ShowBlameModeCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"/>

            <Border Grid.Row="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,1">
                        <Grid>
                            <TextBlock Text="Unstaged Files" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- The single discard button — trash icon with a count badge that only
                                     appears once 2+ files are multi-selected,
                                     counting selections across BOTH the unstaged and staged lists,
                                     since this one button now discards whichever is selected in
                                     either (see DiscardAllOrSelectedAsync). Always enabled whenever
                                     there's anything to discard, staged or unstaged. -->
                                <Button Style="{StaticResource ToolbarButton}" Padding="6,3" Margin="0,0,6,0"
                                        Command="{Binding DiscardAllOrSelectedCommand}"
                                        ToolTip="{Binding SelectedDiscardableFilesCount, Converter={StaticResource DiscardTooltip}}"
                                        AutomationProperties.Name="Discard changes">
                                    <Grid Width="16" Height="16">
                                        <!-- Segoe MDL2 Assets "Delete" glyph (U+E74D) — a reliable
                                             system icon font present on Windows 10+, unlike a raw
                                             emoji whose glyph availability can vary by font/OS
                                             version (an earlier attempt with the 🗑 emoji rendered
                                             as nothing, collapsing the button to a sliver). -->
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource DangerBrush}"/>
                                        <Border Background="{DynamicResource DangerBrush}" CornerRadius="8"
                                                MinWidth="16" Height="16" Padding="4,0"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-6,-8,0"
                                                Visibility="{Binding SelectedDiscardableFilesCount,
                                                             Converter={StaticResource IntAtLeastTwoToVis}}">
                                            <TextBlock Text="{Binding SelectedDiscardableFilesCount,
                                                               Converter={StaticResource DiscardBadgeText}}"
                                                       FontSize="9" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource SuccessButton}" Padding="8,3"
                                        Content="{Binding SelectedWorkingFiles.Count,
                                                   Converter={StaticResource BulkActionLabel}, ConverterParameter=Stage}"
                                        Command="{Binding StageAllCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ListView x:Name="UnstagedListView" Grid.Row="1"
                              Style="{StaticResource DarkListView}"
                              ItemContainerStyle="{StaticResource DarkListViewItem}"
                              ItemsSource="{Binding WorkingDirFiles}"
                              SelectedItem="{Binding SelectedFile}"
                              SelectionMode="Extended">
                        <i:Interaction.Behaviors>
                            <behaviors:ListViewMultiSelectBehavior SelectedItems="{Binding SelectedWorkingFiles}"/>
                        </i:Interaction.Behaviors>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FileChange}">
                                <Grid Height="26" Margin="4,0" Background="Transparent"
                                      Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14"
                                            Background="{Binding Kind, Converter={StaticResource KindToColor}}"
                                            CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Path}" VerticalAlignment="Center"
                                               Margin="6,0" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                    <Button Grid.Column="2" Content="+" Width="20" Height="20"
                                AutomationProperties.Name="Stage file"
                                            Style="{StaticResource ToolbarButton}" Padding="0"
                                            Command="{Binding DataContext.StageFileCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Stage"/>
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Stage"
                                                      Command="{Binding PlacementTarget.Tag.StageFileCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Discard changes"
                                                      Command="{Binding PlacementTarget.Tag.DiscardFileCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Stash selected files…"
                                                      Command="{Binding PlacementTarget.Tag.StashSelectedFilesCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Add to .gitignore"
                                                      Command="{Binding PlacementTarget.Tag.AddToGitignoreCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Track with Git LFS…"
                                                      Command="{Binding PlacementTarget.Tag.TrackWithLfsCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="Open"
                                                      Command="{Binding PlacementTarget.Tag.OpenFileCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Reveal in Explorer"
                                                      Command="{Binding PlacementTarget.Tag.RevealFileCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Copy path"
                                                      Command="{Binding PlacementTarget.Tag.CopyFilePathCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="View File History"
                                                      Command="{Binding PlacementTarget.Tag.ShowHistoryModeCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Blame"
                                                      Command="{Binding PlacementTarget.Tag.ShowBlameModeCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Commit message + author -->
            <Border Grid.Row="5" Padding="8,6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="60"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Margin="0,0,0,4"
                             ToolTip="Ctrl+Enter to commit">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Modifiers="Control"
                                        Command="{Binding CommitCommand}"/>
                        </TextBox.InputBindings>
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Subject line ≤ 50 chars, blank line, body wrapped at ~72"
                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding CommitSubjectLength, StringFormat='{}{0}/50'}"
                                   FontSize="10" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="Committing as "/>
                            <Run Text="{Binding AuthorName, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text=" &lt;"/>
                            <Run Text="{Binding AuthorEmail, Mode=OneWay}"/>
                            <Run Text="&gt;"/>
                        </TextBlock>
                        <Button Content="Change…" Style="{StaticResource ToolbarButton}"
                                Padding="4,0" Margin="6,0,0,0" FontSize="10"
                                Command="{Binding OpenIdentitySettingsCommand}"
                                ToolTip="Set your name/email in Settings → Profile"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Commit buttons + options -->
            <Border Grid.Row="6" Padding="8,6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <CheckBox Content="Amend last commit"
                                  IsChecked="{Binding IsAmend}"
                                  Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                  ToolTip="Rewrite the previous commit with the staged changes and this message"/>
                        <Button Content="⋯" Style="{StaticResource ToolbarButton}"
                                Padding="6,0" Margin="12,0,0,0" FontSize="11"
                                Click="CommitOptionsButton_Click"
                                ToolTip="More commit options">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Sign-off (adds Signed-off-by trailer)"
                                              IsCheckable="True" IsChecked="{Binding SignOff}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Commit" Style="{StaticResource AccentButton}"
                                Padding="0,8"
                                Command="{Binding CommitCommand}"/>
                        <Button Grid.Column="2" Content="Commit &amp; Push" Style="{StaticResource ToolbarButton}"
                                Padding="0,8"
                                Command="{Binding CommitAndPushCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
