<Window x:Class="PickleGit.Views.InteractiveRebaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PickleGit.Models"
        Title="Interactive Rebase"
        Width="720" Height="600" MinWidth="600" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/pickle.ico"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4">
            <Run Text="Interactive Rebase onto "/>
            <Run Text="{Binding OntoLabel, Mode=OneWay}" FontWeight="Bold"/>
            <Run Text=" ("/>
            <Run Text="{Binding Items.Count, Mode=OneWay}"/>
            <Run Text=" commits)"/>
        </TextBlock>
        <TextBlock Grid.Row="1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="Oldest commit first, matching the order git applies them. Use ▲/▼ to reorder. Squash/Fixup merges a commit into the one above it; Reword lets you type a new message without an external editor."/>

        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <ListView ItemsSource="{Binding Items}" Style="{StaticResource DarkListView}" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:RebaseTodoItem}">
                        <Grid Margin="4,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                <Button Content="&#x25B2;" Width="20" Height="20" Padding="0" FontSize="9"
                                AutomationProperties.Name="Move up"
                                        Style="{StaticResource ToolbarButton}" ToolTip="Move up"
                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="&#x25BC;" Width="20" Height="20" Padding="0" FontSize="9" Margin="2,0,0,0"
                                AutomationProperties.Name="Move down"
                                        Style="{StaticResource ToolbarButton}" ToolTip="Move down"
                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>

                            <Button Grid.Row="0" Grid.Column="1" Width="100" Margin="4,0"
                                    Style="{StaticResource ToolbarButton}"
                                    Content="{Binding Action}"
                                    ToolTip="Click to cycle Pick / Reword / Squash / Fixup / Edit (stop to amend) / Break (pause after) / Drop"
                                    Command="{Binding DataContext.CycleActionCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ShortSha}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding MessageShort}" FontSize="12"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>

                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource DarkTextBox}"
                                     Margin="4,4,0,0" FontSize="11"
                                     Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding IsReword, Converter={StaticResource BoolToVis}}"
                                     ToolTip="New commit message (applied via `git commit --amend -F`, no editor needed)"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="Loading commits…" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}" MinWidth="90" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Start Rebase" Style="{StaticResource AccentButton}" MinWidth="120"
                    Command="{Binding StartCommand}"/>
        </StackPanel>
    </Grid>
</Window>
