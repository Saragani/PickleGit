<UserControl x:Class="PickleGit.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:PickleGit.ViewModels"
             xmlns:ctrl="clr-namespace:PickleGit.Controls"
             xmlns:conv="clr-namespace:PickleGit.Converters"
             xmlns:behaviors="clr-namespace:PickleGit.Behaviors"
             xmlns:models="clr-namespace:PickleGit.Models">

    <UserControl.Resources>
        <conv:IndentLevelToMarginConverter x:Key="IndentToMargin"/>

        <!-- Reusable chevron style: collapsed = right-pointing triangle, expanded = down-pointing.
             Bound per-template since header rows snapshot IsExpanded onto the SidebarRow itself,
             while branch-group rows bind live through Payload (BranchNodeViewModel.IsExpanded). -->
        <Style x:Key="SidebarChevron" TargetType="Path">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
            <!-- Both triangles share an identical 6x6 bounding box (x:1-7, y:1-7) — the expanded
                 one is the collapsed one rotated 90°. Uniform stretch previously scaled the two
                 states differently because their bounding boxes had swapped (not matching)
                 width/height, making the expanded glyph render visibly smaller. -->
            <Setter Property="Data" Value="M 1 1 L 7 4 L 1 7 Z"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="Data" Value="M 1 1 L 7 1 L 4 7 Z"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <conv:SidebarRowTemplateSelector x:Key="SidebarSelector">

            <!-- ══════════════════════════ Section headers ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.LocalBranchesHeaderTemplate>
                <DataTemplate>
                    <Grid Background="Transparent" MouseLeftButtonDown="ToggleLocalBranchesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <!-- Hand-drawn (no font glyph for "git branch" exists in Segoe Fluent Icons,
                             confirmed via the official icon list) so it can't suffer a font-mapping
                             mismatch the way a wrong/missing codepoint would. -->
                        <!-- Long trunk (top-left to bottom) with a short branch curving off to the
                             right partway down — an asymmetric shape reads more clearly as "git
                             branch" than a symmetric wishbone/fork did. -->
                        <Canvas Grid.Column="1" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center">
                            <Line X1="3.5" Y1="4.6" X2="3.5" Y2="9.4" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.4"/>
                            <Path Data="M3.5,8.5 C4.5,7 7,6.5 8.9,6" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.4"/>
                            <Ellipse Canvas.Left="1.9" Canvas.Top="1.4" Width="3.2" Height="3.2" Fill="{DynamicResource TextSecondaryBrush}"/>
                            <Ellipse Canvas.Left="1.9" Canvas.Top="9.4" Width="3.2" Height="3.2" Fill="{DynamicResource TextSecondaryBrush}"/>
                            <Ellipse Canvas.Left="8.9" Canvas.Top="4.4" Width="3.2" Height="3.2" Fill="{DynamicResource TextSecondaryBrush}"/>
                        </Canvas>
                        <TextBlock Grid.Column="2" Text="LOCAL BRANCHES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.LocalBranchesHeaderTemplate>

            <conv:SidebarRowTemplateSelector.RemoteBranchesHeaderTemplate>
                <DataTemplate>
                    <Grid Background="Transparent" MouseLeftButtonDown="ToggleRemoteBranchesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE753;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="REMOTE BRANCHES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.RemoteBranchesHeaderTemplate>

            <conv:SidebarRowTemplateSelector.TagsHeaderTemplate>
                <DataTemplate>
                    <Grid Background="Transparent" MouseLeftButtonDown="ToggleTagsHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE8EC;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TAGS" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.TagsHeaderTemplate>

            <conv:SidebarRowTemplateSelector.StashesHeaderTemplate>
                <DataTemplate>
                    <Grid Background="Transparent" MouseLeftButtonDown="ToggleStashesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="STASHES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.StashesHeaderTemplate>

            <conv:SidebarRowTemplateSelector.RemotesHeaderTemplate>
                <DataTemplate>
                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                          Background="Transparent" MouseLeftButtonDown="ToggleRemotesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE71B;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="REMOTES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add remote…"
                                          Command="{Binding PlacementTarget.Tag.AddRemoteCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.RemotesHeaderTemplate>


            <conv:SidebarRowTemplateSelector.PullRequestsHeaderTemplate>
                <DataTemplate>
                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                          Background="Transparent" MouseLeftButtonDown="TogglePullRequestsHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE751;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="PULL REQUESTS" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <!-- Only shown when the last load genuinely failed (auth/network/rate-limit) —
                             an empty list from zero open PRs never sets this. -->
                        <TextBlock Grid.Column="2" Text="&#x26A0;" FontSize="10" Margin="0,0,4,0"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DangerBrush}"
                                   ToolTip="{Binding Tag.Hosting.PullRequestsLoadError, RelativeSource={RelativeSource AncestorType=Grid}}"
                                   Visibility="{Binding Tag.Hosting.PullRequestsLoadError, RelativeSource={RelativeSource AncestorType=Grid}, Converter={StaticResource NullToVis}}"/>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Refresh"
                                          Command="{Binding PlacementTarget.Tag.Hosting.RefreshPullRequestsCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Create Pull Request…"
                                          Command="{Binding PlacementTarget.Tag.Hosting.CreatePullRequestCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Open repository in browser"
                                          Command="{Binding PlacementTarget.Tag.Hosting.OpenRepoWebPageCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.PullRequestsHeaderTemplate>

            <conv:SidebarRowTemplateSelector.SubmodulesHeaderTemplate>
                <DataTemplate>
                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                          Background="Transparent" MouseLeftButtonDown="ToggleSubmodulesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="SUBMODULES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Init and update all"
                                          Command="{Binding PlacementTarget.Tag.InitAllSubmodulesCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Add submodule…"
                                          Command="{Binding PlacementTarget.Tag.AddSubmoduleCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.SubmodulesHeaderTemplate>

            <conv:SidebarRowTemplateSelector.WorktreesHeaderTemplate>
                <DataTemplate>
                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                          Background="Transparent" MouseLeftButtonDown="ToggleWorktreesHeader">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                        <TextBlock Grid.Column="1" Text="&#xE8C8;" FontFamily="Segoe Fluent Icons" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="WORKTREES" Margin="0,4,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add worktree…"
                                          Command="{Binding PlacementTarget.Tag.AddWorktreeCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.WorktreesHeaderTemplate>

            <!-- ══════════════════════════ Local branches ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.LocalBranchGroupTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}" Background="Transparent"
                              MouseLeftButtonDown="ToggleBranchGroup">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="2,3,0,3"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.LocalBranchGroupTemplate>

            <conv:SidebarRowTemplateSelector.LocalBranchLeafTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="BranchNode_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="BranchNode_PreviewMouseMove"
                              Drop="BranchNode_Drop">
                            <Grid.InputBindings>
                                <!-- Double-click on a leaf branch node checks it out -->
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.CheckoutBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding BranchInfo}"/>
                            </Grid.InputBindings>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Green checkmark for the current (HEAD) branch -->
                            <TextBlock Grid.Column="0" Text="✓"
                                       Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                       Visibility="{Binding IsHead, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="2,3,0,3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHead}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Ahead ↑ / Behind ↓ indicators, right-aligned. Fixed-width column
                                 (not Auto) — a VirtualizingStackPanel/Recycling defect can leave a
                                 realized row's Auto column stale after a width-only resize, making
                                 it vanish entirely; a fixed width needs no such measurement. -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,2,0">
                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="4,0" Margin="0,0,4,0"
                                        ToolTip="This branch has an open pull request"
                                        Visibility="{Binding HasOpenPr, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="PR" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <!-- Hand-drawn filled triangles instead of the Unicode ↑/↓ glyphs or a
                                     Segoe Fluent Icons codepoint — this session already hit a Fluent
                                     Icons glyph that rendered as an unrecognizable sliver despite being
                                     the officially-correct codepoint, and the plain ↑/↓ characters read
                                     as thin/small even at a larger FontSize. A solid vector triangle
                                     scales to any size cleanly and can't suffer a font-rendering miss. -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,0"
                                            Visibility="{Binding HasAhead, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xF0AD;" FontSize="9" FontFamily="Segoe Fluent Icons"
                                        Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding AheadBy, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding HasBehind, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xF0AE;" FontSize="9" FontFamily="Segoe Fluent Icons"
                                        Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding BehindBy, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Checkout"
                                              Command="{Binding PlacementTarget.Tag.CheckoutBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Create Pull Request…"
                                              Visibility="{Binding PlacementTarget.Tag.Hosting.HasHostingProvider,
                                                           Converter={StaticResource BoolToVis},
                                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.Tag.Hosting.CreatePullRequestCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Fetch this branch"
                                              ToolTip="Fast-forwards this branch to match its upstream, without checking it out"
                                              Visibility="{Binding PlacementTarget.DataContext.CanFetchBranch,
                                                           Converter={StaticResource BoolToVis},
                                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.Tag.FetchBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Diff against current branch"
                                              Visibility="{Binding PlacementTarget.DataContext.IsHead,
                                                           Converter={StaticResource InvertBoolToVis},
                                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.Tag.CompareWithCurrentCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Merge into current"
                                              Visibility="{Binding PlacementTarget.DataContext.IsHead,
                                                           Converter={StaticResource InvertBoolToVis},
                                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.Tag.MergeBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Advanced"
                                              Visibility="{Binding PlacementTarget.DataContext.IsHead,
                                                           Converter={StaticResource InvertBoolToVis},
                                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem Header="Merge into current (no fast-forward)"
                                                  Command="{Binding PlacementTarget.Tag.MergeBranchNoFfCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Merge into current (fast-forward only)"
                                                  Command="{Binding PlacementTarget.Tag.MergeBranchFfOnlyCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Squash-merge into current"
                                                  Command="{Binding PlacementTarget.Tag.MergeBranchSquashCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Rebase current branch onto this"
                                                  Command="{Binding PlacementTarget.Tag.RebaseOntoBranchCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Interactive rebase current branch onto this…"
                                                  Command="{Binding PlacementTarget.Tag.InteractiveRebaseOntoBranchCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </MenuItem>
                                    <MenuItem Header="Rename…"
                                              Command="{Binding PlacementTarget.Tag.RenameBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Copy branch name"
                                              Command="{Binding PlacementTarget.Tag.CopyBranchNameCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.Tag.DeleteBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.LocalBranchLeafTemplate>

            <!-- ══════════════════════════ Remote branches ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.RemoteBranchGroupTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}" Background="Transparent"
                              MouseLeftButtonDown="ToggleBranchGroup">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Style="{StaticResource SidebarChevron}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="2,3,0,3"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.RemoteBranchGroupTemplate>

            <conv:SidebarRowTemplateSelector.RemoteBranchLeafTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <Grid.InputBindings>
                                <!-- Double-click a remote branch → checkout as local tracking branch -->
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.CheckoutRemoteBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding BranchInfo}"/>
                            </Grid.InputBindings>
                            <TextBlock Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" Margin="2,3,0,3"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Checkout as local branch"
                                              Command="{Binding PlacementTarget.Tag.CheckoutRemoteBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Copy branch name"
                                              Command="{Binding PlacementTarget.Tag.CopyBranchNameCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete from remote…"
                                              Command="{Binding PlacementTarget.Tag.DeleteRemoteBranchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext.BranchInfo,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.RemoteBranchLeafTemplate>

            <!-- ══════════════════════════ Tags ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.TagTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <TextBlock Text="{Binding Name}" Margin="4,3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Checkout (detached)"
                                              Command="{Binding PlacementTarget.Tag.CheckoutTagCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Push to remote"
                                              Command="{Binding PlacementTarget.Tag.PushTagCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.Tag.DeleteTagCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Delete on remote…"
                                              Command="{Binding PlacementTarget.Tag.DeleteTagOnRemoteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.TagTemplate>

            <!-- ══════════════════════════ Stashes ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.StashTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <Grid.InputBindings>
                                <!-- Click a stash → preview its files in the detail panel -->
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectStashCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding}"/>
                            </Grid.InputBindings>
                            <TextBlock Text="{Binding Message}" Margin="4,3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Apply (keep stash)"
                                              Command="{Binding PlacementTarget.Tag.ApplyStashCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Pop (apply and remove)"
                                              Command="{Binding PlacementTarget.Tag.PopStashItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Drop"
                                              Command="{Binding PlacementTarget.Tag.DropStashCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.StashTemplate>

            <!-- ══════════════════════════ Remotes ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.RemoteTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <StackPanel Orientation="Vertical" Margin="4,3">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Url}" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edit URL…"
                                              Command="{Binding PlacementTarget.Tag.EditRemoteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Add remote…"
                                              Command="{Binding PlacementTarget.Tag.AddRemoteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Remove"
                                              Command="{Binding PlacementTarget.Tag.RemoveRemoteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.RemoteTemplate>

            <!-- ══════════════════════════ Pull requests ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.PullRequestTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.Hosting.OpenPullRequestCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding}"/>
                            </Grid.InputBindings>
                            <StackPanel Orientation="Vertical" Margin="4,3">
                                <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding DisplayRoute, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Author, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in browser"
                                              Command="{Binding PlacementTarget.Tag.Hosting.OpenPullRequestCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.PullRequestTemplate>

            <!-- ══════════════════════════ Submodules ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.SubmoduleTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenSubmoduleAsTabCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding}"/>
                            </Grid.InputBindings>
                            <StackPanel Orientation="Vertical" Margin="4,3">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding Path, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding StatusLabel, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Init / update"
                                              Command="{Binding PlacementTarget.Tag.UpdateSubmoduleCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Open as tab"
                                              Command="{Binding PlacementTarget.Tag.OpenSubmoduleAsTabCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="Sync URL and update"
                                              Command="{Binding PlacementTarget.Tag.SyncSubmoduleCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Deinit…"
                                              Command="{Binding PlacementTarget.Tag.DeinitSubmoduleCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.SubmoduleTemplate>

            <!-- ══════════════════════════ Worktrees ══════════════════════════ -->

            <conv:SidebarRowTemplateSelector.WorktreeTemplate>
                <DataTemplate>
                    <Border Margin="{Binding IndentLevel, Converter={StaticResource IndentToMargin}}">
                        <Grid DataContext="{Binding Payload}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"
                              Background="Transparent">
                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenWorktreeAsTabCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                              CommandParameter="{Binding}"/>
                            </Grid.InputBindings>
                            <StackPanel Orientation="Vertical" Margin="4,3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (main)" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Visibility="{Binding IsMain, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text=" 🔒" Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Branch}" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open as tab"
                                              Command="{Binding PlacementTarget.Tag.OpenWorktreeAsTabCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Remove"
                                              Command="{Binding PlacementTarget.Tag.RemoveWorktreeCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </Border>
                </DataTemplate>
            </conv:SidebarRowTemplateSelector.WorktreeTemplate>

        </conv:SidebarRowTemplateSelector>
    </UserControl.Resources>

    <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1" Padding="6,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="🔍" FontSize="11" VerticalAlignment="Center"
                       Margin="2,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Grid.Column="1" x:Name="SidebarSearchBox"
                     Style="{StaticResource DarkTextBox}"
                     ToolTip="Filter branches, tags, stashes, remotes…"
                     TextChanged="SidebarSearchBox_TextChanged"/>
        </Grid>
    </Border>

    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
        <ListView x:Name="SidebarList"
                  Style="{StaticResource DarkListView}"
                  ItemContainerStyle="{StaticResource SidebarListViewItem}"
                  ItemTemplateSelector="{StaticResource SidebarSelector}"
                  SelectionMode="Single"
                  SelectionChanged="SidebarList_SelectionChanged"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  ScrollViewer.CanContentScroll="True"
                  BorderThickness="0"/>
    </Border>

    <!-- Busy overlay: blocks interaction and shows a spinner while git ops run -->
    <Border Grid.Row="1" Background="{DynamicResource OverlayScrimBrush}"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Width="120" Height="3"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceAltBrush}"/>
            <TextBlock Text="Working…" Margin="0,8,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
        </StackPanel>
    </Border>
    </Grid>
</UserControl>
